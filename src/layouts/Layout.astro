---
import Drawer from "../components/layout/Drawer.astro";
import Sidebar from "../components/layout/Sidebar.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";

import Social from "../components/layout/Social.astro";
import { ClientRouter } from "astro:transitions";

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preload" href="/fonts/Inter-VariableFont_opsz,wght.ttf" as="font" type="font/ttf" crossorigin/>
  </head>

  <body class="bg-background/90 text-slate-300 text-md scrollbar-thin overflow-x-hidden">
    <!-- <Drawer /> -->
    <div class="min-h-screen flex">
      <Sidebar />
      <Navbar />
      <div class="md:fixed hidden bottom-4 left-4">
        <Social />
      </div>

      <main class="
             p-5
             mr-3
             max-w-6xl 
             text-md 
             leading-6 
             lg:text-lg 
             font-normal 
             tracking-wide 
             text-slate-300/80
             font-serif 
             antialiased 
             md:subpixel-antialiased">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>


