---
import portfolio from "../../data/portfolio.json";
import { Icon } from "astro-icon/components";
---

<button id="menu-button" class="fixed sm:hidden top-2 right-2 p-1 z-1 text-white">
  <Icon name="lucide:menu" class="h-7 w-7" />
</button>

<nav class="md:p-3 md:w-sm font-serif">

  <ul class="fixed top-2/5 lg:flex flex-col hidden items-start gap-3">
    {portfolio.navigation.map((item) => (
      <li>
        <a
          href={item.href}
          class="
            group
            relative
            inline-flex
            items-center
            pl-12
            before:absolute
            before:left-0
            before:top-1/2
            before:-translate-y-1/2
            before:h-px
            before:w-8
            before:bg-white/50
            before:transition-all
            before:duration-100

            hover:before:w-16
            hover:before:bg-white
          "
        >
          <span
            class="
              text-white/50
              transition-all
              duration-100
              group-hover:text-white
              lg:group-hover:translate-x-8
            "
          >
            {item.title}
          </span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  @reference "../../styles/global.css";

  @keyframes dropDown {
    from {
      opacity: 0;
      transform: translate(0%, -30px);
    }

    to {
      opacity: 1;
      transform: translate(0%, 0);
    }
  }

  .navbar {
    animation: dropDown 0.6s ease-out;
  }
</style>