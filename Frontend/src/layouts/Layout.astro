---
import Drawer from "../components/layout/Drawer.astro";
import Sidebar from "../components/layout/Sidebar.astro";
import Navbar from "../components/layout/Navbar.astro";

import Social from "../components/layout/Social.astro";
import css from "../styles/global.css";
import { ClientRouter } from "astro:transitions";

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="bg-slate-900 text-gray-300 text-md scrollbar-thin">
    <Drawer />
    <div class="flex">
      <Sidebar />
      <Navbar />
      <div class="md:fixed hidden bottom-4 left-4">
        <Social />
      </div>

      <main class="lg:ml-20 
             p-5
             mr-3 
             max-w-6xl 
             text-md 
             leading-6 
             lg:text-lg 
             font-normal 
             tracking-wide 
             text-slate-400 
             font-serif 
             antialiased 
             md:subpixel-antialiased">
        <slot />
      </main>
    </div>
  </body>
</html>


