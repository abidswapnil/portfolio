---
import portfolio from "../../data/portfolio.json";
import { Icon } from "astro-icon/components";
---

<!-- <button id="menu-button" class="fixed sm:hidden top-2 right-2 rounded-full bg-white/10 p-1 text-white backdrop-blur-md">
  <Icon name="lucide:menu" class="h-7 w-7" />
</button> -->

<nav class="font-serif">

  <ul class="
      fixed
      top-0
      left-0
      z-1
      w-full
      bg-background/50
      backdrop-blur-xl
      hidden sm:flex lg:hidden
      justify-center
      gap-8
      px-8
      py-4
    ">    
    {portfolio.navigation.map((item) => (
      <li>
        <a
          href={item.href}
          class="
            relative
            font-semibold
            text-white/50
            transition-color
            duration-300
            hover:text-white
            after:absolute
            after:-bottom-1
            after:left-0
            after:h-px
            after:w-0
            after:bg-cyan-400
            after:transition-color
            after:duration-300
            hover:after:w-full
          "
        >
          <span
            class="
              text-white/50
              transition-color
              duration-300
              group-hover:translate-x-6
              group-hover:text-white
            "
          >
          {item.title}
          </span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  @reference "../../styles/global.css";

  @keyframes dropDown {
    from {
      opacity: 0;
      transform: translate(0%, -30px);
    }

    to {
      opacity: 1;
      transform: translate(0%, 0);
    }
  }

  .navbar {
    animation: dropDown 0.6s ease-out;
  }
</style>