---
import portfolio from "../../data/portfolio.json";
import { Icon } from "astro-icon/components";
---

<button id="menu-btn" class="fixed md:hidden top-2 right-2 rounded-full bg-white/10 p-1 text-white backdrop-blur-md">
  <Icon name="lucide:menu" class="h-7 w-7" />
</button>

<nav class="md:p-3 w-2/8 font-serif">

  <ul class="fixed top-2/5 md:flex md:flex-col hidden items-start gap-3">
    {portfolio.navigation.map((item) => (
      <li>
        <a
          href={item.href}
          class="
            group
            relative
            inline-flex
            items-center
            pl-10
            font-semibold
            before:absolute
            before:left-0
            before:top-1/2
            before:h-px
            before:w-8
            before:-translate-y-1/2
            before:bg-white/50
            before:transition-all
            before:duration-300
            
            hover:before:w-14
            hover:before:bg-white
          "
        >
          <span
            class="
              text-white/50
              transition-all
              duration-300
              group-hover:translate-x-6
              group-hover:text-white
            "
          >
          {item.title}
          </span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  @reference "../../styles/global.css";

  @keyframes dropDown {
    from {
      opacity: 0;
      transform: translate(0%, -30px);
    }

    to {
      opacity: 1;
      transform: translate(0%, 0);
    }
  }

  .navbar {
    animation: dropDown 0.6s ease-out;
  }
</style>