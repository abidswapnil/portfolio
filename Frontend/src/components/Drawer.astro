---
import css from "../styles/global.css";
import { Icon } from "astro-icon/components";
import portfolio from "../data/portfolio.json";
---

<aside
  id="drawer"
  class="fixed inset-y-0 w-full right-0 translate-x-full bg-surface z-50 shadow-xl transition-transform duration-300 font-serif">    
  <div class="flex h-full flex-col">
    <!-- Header -->

    <!-- Drawer Items -->
  <nav class="">
    <button
      id="close-btn"
      class="absolute top-3 right-3 rounded-full bg-white/10 p-1 text-white backdrop-blur-md"
    >
      <Icon name="lucide:x" class="h-7 w-7" />
    </button>

    <ul class="flex flex-col items-end gap-3 pt-16 pr-5">
      {portfolio.navigation.map((item) => (
        <li>
          <a class="link hover:text-white" href={item.href}>
            {item.title}
          </a>
        </li>
      ))}
    </ul>
  </nav> 
  </div>
</aside>

<script>
  const links = document.querySelectorAll(".link")
  const drawer = document.getElementById("drawer")
  const closeBtn = document.getElementById("close-btn");
  const menuBtn = document.getElementById("menu-btn")

  function openDrawer() {
    drawer?.classList.remove("translate-x-full");
  };
  
  function closeDrawer() {
    drawer?.classList.add("translate-x-full");
  };
  
  menuBtn?.addEventListener("click", openDrawer);
  closeBtn?.addEventListener("click", closeDrawer);
  
  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();

      closeDrawer();

      setTimeout(() => {
        window.location.href = link.href;
      }, 300); // match your transition duration
    });
});

</script>
