
---
import { Icon } from "astro-icon/components";
const { grade, idx } = Astro.props

const getGrade = (grade:String) => {

    if (grade == "A") {
       return "👽";
    }
}


---
<div class="flex gap-2">
	<span
		id={"grade-" + idx}
		data-idx={idx}
		data-grade={grade}
		class="inline-flex
		items-center
		rounded-md
		bg-white/10
    opacity-0
		px-2
		py-1
		text-sm
		font-medium
		text-gray-300
		shrink-0
		transition-colors"
	>
	{getGrade(grade)}
	</span>
	<button
			id="lock"
			class="lock-btn"
			data-idx={idx}
			data-grade={grade}
			class="group inline-flex items-center justify-center
			h-7 w-7
			rounded-md
			bg-white/10
			border border-white/10
			backdrop-blur-md
			text-white
			transition-all duration-300
			hover:bg-white/20
			hover:scale-105
			hover:shadow-lg
			active:scale-95
			cursor-pointer"
			title="Unlock"
			>
			<span id={`locked-${idx}`} class="cursor-pointer flex gap-2 text-lime-500" >
				<Icon name="twemoji:locked"/>
			</span>
			<span id={`unlocked-${idx}`} class="hidden cursor-pointer  gap-2 text-amber-300">
				<Icon name="twemoji:unlocked" /> Sorry!! Not for random visitor
			</span>
	</button>
</div>

<script>
	document.addEventListener("click", (event) => {
		if (!(event.target instanceof Element)) return;
			const button = event.target instanceof Element ? event.target.closest(".lock-btn") : null;
			if (!(button instanceof HTMLElement)) return;

			const idx = button.dataset.idx;
			const grade_id = "grade-" + idx;

			const grade = document.getElementById(grade_id);
			if (!grade) return;

			const locked = document.getElementById(`locked-${idx}`);
			const unlocked = document.getElementById(`unlocked-${idx}`);


			if (locked){
				grade.classList.replace("opacity-0", "opacity-100");
        unlocked?.classList.add("flex")
				locked.classList.add("hidden");
				unlocked?.classList.remove("hidden")
			}

	});
</script>



