---
const { title, exp } = Astro.props
import { Icon } from "astro-icon/components"
---

<div class="accordion group">
  <div class="header  flex border p-3  lg:group-hover:hover:bg-slate-800/50 rounded-lg cursor-pointer  border-cyan-500/30">
    <span class="flex gap-2 group-hover:text-cyan-400 transition-all duration-300 xl:w-170">
      See experience on related skills
    </span>
    <button type="button" class="ml-auto toggle-btn hover:scale-120 transition-transform duration-300 cursor-pointer border border-cyan-500/30 rounded-full bg-white/10 p-1 text-white backdrop-blur-md">
      <Icon name="lucide:chevron-down" class="chevron h-5 w-5"/>
    </button>
  </div>

  <div class="content hidden bg-slate-800/50 rounded-b-lg border border-t-0 border-cyan-500/30 p-4">
    <p set:html={exp} ></p>
  </div>
</div>


<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".toggle-btn").forEach((button) => {
      button.addEventListener("click", () => {
        const accordion = button.closest(".accordion");
        if (!accordion) return;
        const header = accordion.querySelector(".header");
        const content = accordion.querySelector(".content");
        const chevron = accordion.querySelector(".chevron");
        if (!content || !chevron || !header) return;
        
        const isHidden = content.classList.toggle("hidden");
        chevron.classList.toggle("rotate-180", !isHidden);

        if (isHidden) {
          header.classList.replace("rounded-t-lg", "rounded-lg");

        } else {
          header.classList.replace("rounded-lg", "rounded-t-lg");
        }

      });
    });
  });
</script>