---
import { Icon } from "astro-icon/components";
import portfolio from "../../data/portfolio.json";
import Bar from "../ui/Bar.astro";
import Accordion from "../ui/Accordion.astro";

---

<section id="skills" class="scroll-mt-15 min-h-screen flex place-items-center">
	<div>
    <h2 class="text-2xl mb-4 font-semibold">Skill</h2>
    {portfolio.skills.map((skill) => (
      <div class="flex md:px-4 py-5 flex-wrap md:flex-nowrap ">
        <span class="text-md w-90 text-gray-400 text-shadow-emerald-50">{skill.category}</span>
        <div class="w-full">
          <div class="flex flex-wrap gap-2 mb-2">
            {skill.items.join(", ")}
          </div>
          <Accordion />
        </div>
      </div>
        
    ))}
	</div>
</section>