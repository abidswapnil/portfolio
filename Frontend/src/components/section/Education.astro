---
import { Icon } from "astro-icon/components";
import portfolio from "../../data/portfolio.json";
import Grade from "../ui/Grade.astro";

// import ku from "../../assets/ku.png";
// import mmcc from "../../assets/mmcc.png"
// import kzs from "../../assets/kzs.png"


---

<section id="education" class="min-h-screen flex place-items-center">
	<div>
		<h2 class="text-2xl md:hidden">Education</h2>
		{portfolio.education.map((item) => (
			<div class="flex flex-wrap md:flex-nowrap py-2">
				<div class="flex flex-nowrap">
					<span> <Icon name={`twemoji:${item.emoji}`} class="text-xl mr-2"/> </span>
				  <span class="text-lg w-90 text-gray-400 text-shadow-emerald-50">{item.start} - {item.end}</span>
				</div>
				{/* <div class="w-90 hidden md:block">
					<img
						src={item.logo}
						alt="logo"
						class="mx-auto h-30 w-23 object-center rounded-lg shrink-0"
					/>
				</div> */}
				<div
					class="flex w-full flex-col
					px-3 py-2
					rounded-xl
					transition-all duration-300
					hover:py-3
					hover:bg-accent/10
					hover:backdrop-blur-xl"
>					<span class="text-xl mb-1">{item.degree}</span>
					<span class="text-lg">{item.institute}</span>
					{item.research && (<span>Thesis: {item.research}</span>)}
					{item.sec && (<span>Section: {item.sec}</span>)}
					<span class="flex gap-2">
						<span>{item.grade_system}</span>
						<Grade grade = {item.grade} />
					</span>
				</div>
			</div>
		))}	
	</div>
</section>