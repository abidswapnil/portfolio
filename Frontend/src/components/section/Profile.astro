---
import portfolio from "../../data/portfolio.json";
import me from "../../assets/me.jpeg";
import "../../styles/global.css";
import Social from "../../components/layout/Social.astro";

import { Icon } from "astro-icon/components";
import Mail from "../ui/Mail.astro";

const data = portfolio.profile

---
<section id="about" class="scroll-mt-20 min-h-screen flex place-items-center ">
  <div class="md:flex">
    <img
        src={me.src}
        alt="Abid Shahriar"
        class="mx-auto my-auto h-48 w-48 shrink-0 rounded-full object-cover
              border-5 hover:scale-105 transition-transform duration-300 border-cyan-900"
    />
    <div class="md:px-10 py-5">
      <div class="text-4xl md:text-6xl text-gray-200 tracking-wide font-semibold text-nowrap">{data.name}</div>
      <div class="mt-4 font-mono text-nowrap text-xl gap-4 text-slate-400 cursor-default flex">
        {data.title}
        <a href="#" class="group py-auto ">
          <svg class="w-5 h-5 mt-0 text-[#0A66C2] hover:opacity-80 transition-opacity" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
      <span class="typing-wrapper">
        <span class="mt-5 typing text-lg text-gray-300">
          {data.tagline}
        </span>
      </span>
      <p set:html={data.about} class="inline-block mt-2 mx-auto"></p> 
      <div class=" mt-10 mb-6 flex justify-center lg:justify-end">
        <Mail />
      </div>
    </div>
  </div>
</section>