---
import portfolio from "../../data/portfolio.json";
import Badge from "../ui/Badge.astro";
import Icolink from "../ui/Icolink.astro";
import { Icon } from "astro-icon/components";
---

<section id="certifications" class="scroll-mt-15 min-h-screen flex place-items-center">
	<div>
    <h2 class="text-2xl mb-4 font-semibold">Certifications</h2>
    <div class="md:px-4 py-5 absolute">
      <p>{portfolio.certifications.description}</p>
      <ul class=" list-outside absolute mt-4">
        {portfolio.certifications.certificates.map((item) => (
          <li class="group transition-colors duration-300 flex ">
            <div class="font-semibold gap-2 flex item-center text-nowrap">
              <Icon name="lucide:badge-check" class="h-4 w-4 mt-1 text-lime-500 " />
              <p>{item.title} :</p>
            </div>
            <p class="ml-2 ordinal">
              {item.for}
              <Icolink href={item.href} />
            </p>
          </li>
        ))}
      </ul>  
    </div>
	</div>
</section>