---
import portfolio from "../data/portfolio.json";
---
<nav class="navbar fixed top-4 left-1/2 transform -translate-x-1/2 font-serif">
  <ul class="flex items-center gap-8 rounded-full bg-white/10 px-8 py-4 backdrop-blur-md shadow-lg">
    {portfolio.navigation.map((item) => (
      <li>
        <a
          href={item.href}
          class="
            relative
            text-sm
            font-medium
            tracking-wide
            text-white/50
            transition-all
            duration-300
            hover:text-white
            after:absolute
            after:-bottom-1
            after:left-0
            after:h-px
            after:w-0
            after:bg-cyan-400
            after:transition-all
            after:duration-300
            hover:after:w-full
          "
        >
          {item.title}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  @reference "../styles/global.css";

  @keyframes dropDown {
    from {
      opacity: 0;
      transform: translate(0%, -30px);
    }

    to {
      opacity: 1;
      transform: translate(0%, 0);
    }
  }

  .navbar {
    animation: dropDown 0.6s ease-out;
  }
</style>